  "cloudflare": [
    {
      "provider": "cloudflare-workers-ai",
      "baseUrl": "https://api.cloudflare.com/client/v4/accounts/{CLOUDFLARE_ACCOUNT_ID}/ai/v1",
      "env": {
        "CLOUDFLARE_ACCOUNT_ID": "fixture-account"
      },
      "auth": {
        "apiKey": "fixture-cloudflare-key"
      },
      "resolvedBaseUrl": "https://api.cloudflare.com/client/v4/accounts/fixture-account/ai/v1"
    },
    {
      "provider": "cloudflare-ai-gateway",
      "baseUrl": "https://gateway.ai.cloudflare.com/v1/{CLOUDFLARE_ACCOUNT_ID}/{CLOUDFLARE_GATEWAY_ID}/openai",
      "env": {
        "CLOUDFLARE_ACCOUNT_ID": "fixture-account",
        "CLOUDFLARE_GATEWAY_ID": "fixture-gateway"
      },
      "auth": {
        "headers": {
          "cf-aig-authorization": "Bearer fixture-cloudflare-key",
          "Authorization": null,
          "x-api-key": null
        }
      },
      "resolvedBaseUrl": "https://gateway.ai.cloudflare.com/v1/fixture-account/fixture-gateway/openai"
    }
