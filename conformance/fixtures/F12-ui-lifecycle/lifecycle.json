        ]
      },
      {
        "step": "removed-by-key",
        "above": [
          "",
          "outer"
        ],
        "below": [
          "nested"
        ]
      },
      {
        "step": "cleared",
        "above": [
          ""
        ],
        "below": []
      }
    ],
    "events": [
      "render",
      "render",
      "factory:replacement",
      "render",
      "factory:outer:start",
      "factory:nested",
      "render",
      "factory:outer:end",
      "render",
      "dispose:replacement",
      "render",
      "dispose:outer",
      "dispose:nested",
      "render"
    ]
  },
  "hiddenThinking": {
