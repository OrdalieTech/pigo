  "toolsExpanded": {
    "events": [
      "expand:built-in-header:true",
      "expand:resource:true",
      "expand:chat:true",
      "render",
      "factory:custom-header",
      "expand:custom-header:true",
      "render",
      "expand:custom-header:false",
      "expand:resource:false",
      "expand:chat:false",
      "render",
      "dispose:custom-header",
      "expand:built-in-header:false",
      "render"
    ],
    "final": {
      "toolsExpanded": false,
      "activeHeader": "built-in-header",
      "builtInExpanded": false,
      "resourceExpanded": false,
      "chatExpanded": false
    }
  },
  "customOverlay": {
    "options": {
      "dynamicCalls": 1,
      "dynamicOptions": {
        "anchor": "top-right",
        "width": "50%",
        "margin": {
          "top": 2,
          "right": 3,
          "bottom": 4,
          "left": 5
        },
        "offsetX": -1,
        "offsetY": 1
      },
      "fallbackOptions": {
        "width": 23
      }
    },
    "earlyDone": {
      "result": "early-done",
      "overlayShows": 0,
      "disposeCount": 0
    },
    "disposeFailure": {
      "result": "dispose-done",
      "disposeCount": 1,
      "rejected": false
    },
    "factoryFailure": "factory failed",
    "handle": {
      "initial": {
        "hasOverlay": true,
        "hidden": false,
        "handleFocused": true,
        "editorFocused": false,
        "overlayFocused": true
      },
      "unfocusedToPrevious": {
        "hasOverlay": true,
        "hidden": false,
        "handleFocused": false,
        "editorFocused": true,
        "overlayFocused": false
      },
      "unfocusedToTarget": {
        "hasOverlay": true,
        "hidden": false,
        "handleFocused": false,
        "editorFocused": true,
        "overlayFocused": false
      },
      "unfocusedToNull": {
        "hasOverlay": true,
        "hidden": false,
        "handleFocused": false,
        "editorFocused": false,
        "overlayFocused": false
      },
      "temporaryHidden": {
        "hasOverlay": false,
        "hidden": true,
        "handleFocused": false,
        "editorFocused": true,
        "overlayFocused": false
      },
      "temporaryRestored": {
        "hasOverlay": true,
        "hidden": false,
        "handleFocused": true,
        "editorFocused": false,
        "overlayFocused": true
      },
      "permanentlyHidden": {
