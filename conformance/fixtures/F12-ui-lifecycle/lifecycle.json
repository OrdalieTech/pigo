{
  "schemaVersion": 2,
  "reset": {
    "events": [
      "selector:hide",
      "input:hide",
      "editor-dialog:hide",
      "overlay:hide-top",
      "terminal-listeners:clear",
      "footer:default",
      "header:default",
      "widgets:clear",
      "statuses:clear",
      "footer:invalidate",
      "editor:default",
      "autocomplete:rebuild",
      "title:default",
      "working-indicator:default",
      "working-status:Working... (escape to interrupt)",
      "thinking-label:default"
    ],
    "disposalOrder": [
      "footer",
      "header",
      "widget-above",
      "widget-below"
    ],
    "final": {
      "selectorPresent": false,
      "inputPresent": false,
      "editorDialogPresent": false,
      "autocompleteWrappers": 0,
      "extensionShortcutPresent": false,
      "workingMessage": null,
      "workingVisible": true,
      "hiddenThinkingLabel": "Thinking..."
    }
  },
  "widgets": {
    "snapshots": [
      {
        "step": "empty",
        "above": [
          ""
        ],
        "below": []
      },
      {
        "step": "eleven-lines-capped",
        "above": [
          "",
          " line-1                                 ",
          " line-2                                 ",
          " line-3                                 ",
          " line-4                                 ",
          " line-5                                 ",
          " line-6                                 ",
          " line-7                                 ",
          " line-8                                 ",
          " line-9                                 ",
          " line-10                                ",
