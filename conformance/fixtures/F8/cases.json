{
  "schemaVersion": 3,
  "argumentCases": [
    {
      "name": "plain",
      "input": "a b c",
      "expected": [
        "a",
        "b",
        "c"
      ]
    },
    {
      "name": "quoted",
      "input": "Button \"onClick handler\" 'disabled support'",
      "expected": [
        "Button",
        "onClick handler",
        "disabled support"
      ]
    },
    {
      "name": "empty-quotes",
      "input": "\"\" \" \"",
      "expected": [
        " "
      ]
    },
    {
      "name": "newlines",
      "input": "label-2\n\nHere is some description #2.",
      "expected": [
        "label-2",
        "Here",
        "is",
        "some",
        "description",
        "#2."
      ]
    },
    {
      "name": "unescaped-quotes",
      "input": "\"quoted \\\"text\\\"\"",
      "expected": [
        "quoted \\text\\"
      ]
    },
    {
      "name": "unicode",
      "input": "日本語 🎉 café",
      "expected": [
        "日本語",
        "🎉",
        "café"
      ]
    }
  ],
  "substitutionCases": [
    {
      "name": "all-forms",
      "content": "$1: $@ ($ARGUMENTS)",
      "args": [
        "first",
        "second",
        "third"
      ],
      "expected": "first: first second third (first second third)"
    },
    {
      "name": "missing-positionals",
      "content": "$1 $2 $3 $4",
      "args": [
        "a",
        "b"
      ],
      "expected": "a b  "
    },
    {
      "name": "multi-digit",
      "content": "$10 $12 $15",
      "args": [
        "val0",
        "val1",
        "val2",
        "val3",
        "val4",
        "val5",
        "val6",
        "val7",
        "val8",
        "val9",
        "val10",
        "val11",
        "val12",
        "val13",
        "val14"
      ],
      "expected": "val9 val11 val14"
    },
    {
      "name": "positional-defaults",
      "content": "${1:-7} ${2:-brief}",
      "args": [],
      "expected": "7 brief"
    },
    {
      "name": "all-default",
      "content": "${@:-default}\n${ARGUMENTS:-default}",
      "args": [],
      "expected": "default\ndefault"
    },
    {
      "name": "non-recursive-argument",
      "content": "$ARGUMENTS",
      "args": [
        "$1",
        "$ARGUMENTS"
      ],
      "expected": "$1 $ARGUMENTS"
    },
    {
      "name": "non-recursive-default",
      "content": "${3:-$ARGUMENTS}",
      "args": [
        "a",
        "b"
      ],
      "expected": "$ARGUMENTS"
    },
    {
      "name": "slice-tail",
      "content": "${@:2}",
      "args": [
        "a",
        "b",
        "c",
        "d"
      ],
      "expected": "b c d"
    },
    {
      "name": "slice-length",
      "content": "${@:2:2}",
      "args": [
        "a",
        "b",
        "c",
        "d"
      ],
      "expected": "b c"
    },
    {
      "name": "slice-zero-start",
      "content": "${@:0}",
      "args": [
        "a",
        "b",
        "c"
      ],
      "expected": "a b c"
    },
    {
      "name": "slice-zero-length",
      "content": "${@:2:0}",
      "args": [
        "a",
        "b",
        "c"
      ],
      "expected": ""
    },
    {
      "name": "escaped-dollar-is-not-special",
      "content": "Price: \\$100",
      "args": [],
      "expected": "Price: \\"
    },
    {
      "name": "unicode",
      "content": "$ARGUMENTS",
      "args": [
        "日本語",
        "🎉",
        "café"
      ],
      "expected": "日本語 🎉 café"
    }
  ],
  "templateCases": [
    {
      "name": "quoted-args",
      "text": "/component Button \"onClick handler\" \"disabled support\"",
      "templates": [
        {
          "name": "component",
          "description": "Create component",
          "content": "Create $1 with ${@:2}"
        }
      ],
      "expected": "Create Button with onClick handler disabled support"
    },
    {
      "name": "newline-separator",
      "text": "/review\nfile.go",
      "templates": [
        {
          "name": "review",
          "description": "Review",
          "content": "Review $1"
        }
      ],
      "expected": "Review file.go"
    },
    {
      "name": "unknown",
      "text": "/missing value",
      "templates": [
        {
          "name": "review",
          "description": "Review",
          "content": "Review $1"
        }
      ],
      "expected": "/missing value"
    },
    {
      "name": "not-command",
      "text": "review file.go",
      "templates": [
        {
          "name": "review",
          "description": "Review",
          "content": "Review $1"
        }
      ],
      "expected": "review file.go"
    }
  ],
  "invocationCases": [
    {
      "name": "without-extra",
      "additionalInstructions": "",
      "expected": "<skill name=\"inspect\" location=\"<fixture>/skills/inspect/SKILL.md\">\nReferences are relative to <fixture>/skills/inspect.\n\nUse inspection tools.\n</skill>"
    },
    {
      "name": "with-extra",
      "additionalInstructions": "Check errors.",
      "expected": "<skill name=\"inspect\" location=\"<fixture>/skills/inspect/SKILL.md\">\nReferences are relative to <fixture>/skills/inspect.\n\nUse inspection tools.\n</skill>\n\nCheck errors."
    }
  ],
  "harnessSubstitutionCases": [
    {
      "name": "positional-slice-and-all",
      "content": "$1 ${@:2} $ARGUMENTS",
      "args": [
        "hello world",
        "test",
        "$1"
      ],
      "expected": "hello world test $1 hello world test $1"
    },
    {
      "name": "default-syntax-is-literal",
      "content": "${4:-fallback}",
      "args": [
        "one",
        "two"
      ],
      "expected": "${4:-fallback}"
    },
    {
      "name": "sequential-reexpansion",
      "content": "$1",
      "args": [
        "$ARGUMENTS",
        "tail"
      ],
      "expected": "$ARGUMENTS tail"
    },
    {
      "name": "slice-zero-length-quirk",
      "content": "${@:2:0}",
      "args": [
        "one",
        "two",
        "three"
      ],
      "expected": ""
    }
  ],
